    --sans:system-ui,-apple-system,'Segoe UI',sans-serif;
    --mono:'JetBrains Mono',ui-monospace,'Cascadia Code',Consolas,monospace;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  html{scroll-behavior:smooth}
  body{background:var(--ink);color:var(--text);font-family:var(--sans);line-height:1.7;-webkit-font-smoothing:antialiased;overflow-x:hidden}
  a{color:var(--accent-bright);text-decoration:none}
  a:hover{text-decoration:underline}
  .wrap{max-width:760px;margin:0 auto;padding:0 28px}

  nav{position:sticky;top:0;z-index:50;background:rgba(23,20,31,.82);backdrop-filter:blur(12px);border-bottom:1px solid var(--line-soft)}
  nav .row{display:flex;align-items:center;justify-content:space-between;height:66px;max-width:760px;margin:0 auto;padding:0 28px}
  .brand{display:flex;align-items:center;gap:12px}
  .brand svg{width:32px;height:32px;flex:none}
  .wm{font-family:var(--grotesk);font-size:22px;font-weight:600;letter-spacing:-.03em;color:var(--text)}
  .back{font-family:var(--mono);font-size:13px;color:var(--muted)}
  .back:hover{color:var(--text);text-decoration:none}

  .head{padding:64px 0 20px;position:relative;overflow:hidden}
  .glow{position:absolute;right:-260px;top:-320px;width:900px;height:900px;border-radius:50%;background:radial-gradient(circle,var(--accent-soft),transparent 62%);pointer-events:none;z-index:0}
  .head .wrap{position:relative;z-index:1}
  .eyebrow{font-family:var(--mono);font-size:12px;letter-spacing:.26em;text-transform:uppercase;color:var(--accent-bright);font-weight:600}
  h1{font-family:var(--grotesk);font-weight:600;font-size:clamp(34px,6vw,46px);line-height:1.08;letter-spacing:-.03em;margin:16px 0 18px}
  .meta{font-family:var(--mono);font-size:12.5px;color:var(--faint);line-height:1.9}
  .meta b{color:var(--muted);font-weight:400}

  .tldr{margin:30px 0 8px;border:1px solid var(--line);border-radius:16px;background:
     radial-gradient(120% 140% at 90% -30%,var(--accent-soft),transparent 55%),var(--panel);
     padding:26px 28px}
  .tldr h2{font-family:var(--grotesk);font-weight:600;font-size:18px;margin-bottom:10px;letter-spacing:-.01em}
  .tldr p{color:var(--muted);font-size:15.5px}

  .content{padding:20px 0 40px}
  .content h2{font-family:var(--grotesk);font-weight:600;font-size:22px;letter-spacing:-.01em;margin:38px 0 14px}
  .content h2:first-child{margin-top:8px}
  .content p{color:var(--muted);font-size:16px;margin-bottom:16px}
  .content ul{list-style:none;margin:0 0 16px}
  .content li{position:relative;padding-left:24px;color:var(--muted);font-size:16px;margin-bottom:11px}
  .content li::before{content:"";position:absolute;left:2px;top:11px;width:7px;height:7px;border-radius:50%;background:var(--accent)}
  .content strong{color:var(--text);font-weight:600}
  .content .num{counter-reset:step;list-style:none;padding:0}
  .content .num li{counter-increment:step;padding-left:44px;margin-bottom:18px}
  .content .num li::before{content:counter(step);top:2px;left:0;width:26px;height:26px;border-radius:8px;background:var(--accent-soft);color:var(--accent-bright);font-family:var(--mono);font-size:13px;font-weight:600;display:flex;align-items:center;justify-content:center}
  code{font-family:var(--mono);font-size:13.5px;color:var(--accent-bright);background:var(--panel);border:1px solid var(--line);border-radius:5px;padding:1px 6px}

  footer.site{border-top:1px solid var(--line-soft);padding:40px 0;margin-top:20px}
  footer.site .row{display:flex;justify-content:space-between;gap:20px;flex-wrap:wrap;align-items:center}
  .foot-links{display:flex;gap:22px;font-family:var(--mono);font-size:12.5px;color:var(--muted)}
  .foot-links a{color:var(--muted)}
  .foot-links a:hover{color:var(--text);text-decoration:none}
  .foot-legal{width:100%;margin-top:22px;font-family:var(--mono);font-size:12px;color:var(--faint);line-height:1.8}

  @media (prefers-reduced-motion:reduce){*{transition:none!important}html{scroll-behavior:auto}}
</style>
