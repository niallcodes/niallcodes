<style>
  :root{
    --ink:#17141f;--panel:#221e2e;--line:#38304a;--line-soft:#2a2438;
    --accent:#a855f7;--accent-bright:#c084fc;--text:#f4f2f8;--muted:#9b93ad;--faint:#6b6480;
