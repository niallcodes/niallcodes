<script>
// Config — swap these after CWS submission
const CWS_URL = 'https://chromewebstore.google.com/detail/hlnkhgnhedehmcinodpfbjdhofckhmfc';      // DocKit on the Chrome Web Store
const STRIPE_URL = 'https://buy.stripe.com/4gMeVfghM9fx8wKe2i9AA09';   // DocKit Pro Stripe payment link

// Wire install buttons
document.querySelectorAll('#nav-install,#hero-install,#free-install,#final-install').forEach(el=>{
  if(CWS_URL!=='#'){el.setAttribute('href',CWS_URL);el.setAttribute('target','_blank');el.setAttribute('rel','noopener');}
});
const proBtn=document.getElementById('pro-buy');
if(STRIPE_URL!=='#'){proBtn.setAttribute('href',STRIPE_URL);proBtn.setAttribute('target','_blank');proBtn.setAttribute('rel','noopener');}

// Nav border on scroll
const nav=document.getElementById('nav');
addEventListener('scroll',()=>nav.classList.toggle('scrolled',scrollY>8));

// ── Multi-tool showcase animation ──
const scenes=['merge','convert','sign','redact','translate'];
const captions={
  merge:'Merge files into one PDF',
  convert:'Convert Word & Excel to PDF',
  sign:'Draw or type your signature',
  redact:'Permanently redact sensitive text',
  translate:'Translate a whole document'
};
const rail=document.getElementById('rail');
const stageCap=document.getElementById('stageCap');
let idx=0, timer=null;

function clearScene(){
  scenes.forEach(s=>document.getElementById('sc-'+s).classList.remove('show'));
  rail.querySelectorAll('.ws-tool').forEach(t=>t.classList.remove('active'));
  // reset per-scene animated bits
  document.getElementById('mergedPg').style.opacity='0';
  document.getElementById('mergeBadge').style.opacity='0';
  const p1=document.querySelector('#sc-merge .p1'),p2=document.querySelector('#sc-merge .p2'),p3=document.querySelector('#sc-merge .p3');
  [p1,p2,p3].forEach(p=>{p.style.transition='none';p.style.transform='none';p.style.opacity='1';});
  document.getElementById('convArrow').style.opacity='0';
  document.getElementById('convPdf').style.opacity='0';
  const sig=document.getElementById('sigPath'); if(sig){sig.style.transition='none';sig.style.strokeDashoffset='220';}
  document.querySelectorAll('#sc-redact .bar').forEach(b=>{b.style.transition='none';b.style.opacity='0';b.style.transform='scaleX(0)';});
  const trPg=document.getElementById('trPg'); if(trPg){trPg.style.transition='none';trPg.style.opacity='1';}
}

function playScene(name){
  const el=document.getElementById('sc-'+name);
  el.classList.add('show');
  rail.querySelector('.ws-tool[data-tool="'+name+'"]').classList.add('active');
  stageCap.textContent=captions[name];

  if(matchMedia('(prefers-reduced-motion:reduce)').matches) return;

  if(name==='merge'){
    const p1=document.querySelector('#sc-merge .p1'),p2=document.querySelector('#sc-merge .p2'),p3=document.querySelector('#sc-merge .p3');
    setTimeout(()=>{
      [p1,p2,p3].forEach(p=>p.style.transition='transform .6s cubic-bezier(.4,.1,.2,1),opacity .5s');
      p1.style.transform='translateX(110px)';p3.style.transform='translateX(-70px)';
      p1.style.opacity='0';p2.style.opacity='0';p3.style.opacity='0';
    },500);
    setTimeout(()=>{const m=document.getElementById('mergedPg');m.style.transition='opacity .5s,transform .5s';m.style.opacity='1';},1050);
    setTimeout(()=>{document.getElementById('mergeBadge').style.transition='opacity .4s';document.getElementById('mergeBadge').style.opacity='1';},1500);
  }
  if(name==='convert'){
    setTimeout(()=>{document.getElementById('convArrow').style.transition='opacity .4s';document.getElementById('convArrow').style.opacity='1';},500);
    setTimeout(()=>{const p=document.getElementById('convPdf');p.style.transition='opacity .6s';p.style.opacity='1';},900);
  }
  if(name==='sign'){
    const sig=document.getElementById('sigPath');
    setTimeout(()=>{sig.style.transition='stroke-dashoffset 1.1s ease';sig.style.strokeDashoffset='0';},500);
  }
  if(name==='redact'){
    const bars=[...document.querySelectorAll('#sc-redact .bar')];
    bars.forEach((b,i)=>setTimeout(()=>{b.style.transition='opacity .2s,transform .45s cubic-bezier(.4,.1,.2,1)';b.style.opacity='1';b.style.transform='scaleX(1)';},500+i*350));
  }
  if(name==='translate'){
    const trPg=document.getElementById('trPg');
    setTimeout(()=>{trPg.style.transition='opacity .25s';trPg.style.opacity='.25';},600);
    setTimeout(()=>{trPg.style.opacity='1';},900);
  }
}

function next(){
  clearScene();
  playScene(scenes[idx]);
  idx=(idx+1)%scenes.length;
  timer=setTimeout(next, 3200);
}
function start(){ clearTimeout(timer); idx=0; next(); }
document.getElementById('replay').addEventListener('click',start);
setTimeout(start,700);

// Year
document.getElementById('year').textContent=new Date().getFullYear();
</script>
