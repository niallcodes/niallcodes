<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DocKit — PDF, Word & Excel Tools, eSign & Translate</title>
<meta name="description" content="DocKit is an all-in-one PDF, Word and Excel toolkit for Chrome. Merge, split, compress and convert PDFs; eSign documents; OCR scanned pages; redact; and translate whole documents — 100% on your device, no account, nothing uploaded.">

<!-- Open Graph -->
<meta property="og:title" content="DocKit — PDF, Word & Excel Tools, eSign & Translate">
<meta property="og:description" content="Every document tool in one place — merge, convert, compress, eSign, OCR, redact and translate. 100% on your device.">
<meta property="og:type" content="website">
<meta property="og:url" content="https://niallcodes.com/dockit">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Inter:wght@400;450;500;600&display=swap" rel="stylesheet">

<style>
:root{
  --ink:#13211d;          /* deep teal-black */
  --ink-soft:#33473f;
  --paper:#F2F7F4;        /* cool off-white with a green cast */
  --paper-deep:#e6efea;
  --cream:#ffffff;
  --line:#d9e6df;
  --teal:#1D9E75;         /* primary / working accent (matches the DocKit app) */
  --teal-deep:#0f6e56;
  --teal-soft:#e3f4ed;
  --gold:#B8860B;         /* Pro */
  --gold-soft:rgba(184,134,11,0.10);
  --muted:#6f7d77;
  --shadow:0 1px 2px rgba(19,33,29,.04), 0 8px 30px rgba(19,33,29,.07);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{
  font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
  background:var(--paper);color:var(--ink);
  line-height:1.6;-webkit-font-smoothing:antialiased;
}
.wrap{max-width:1080px;margin:0 auto;padding:0 24px}
a{color:inherit;text-decoration:none}

.display{font-family:'Fraunces',Georgia,serif;font-weight:500;letter-spacing:-0.02em;line-height:1.05}
.eyebrow{font-size:12px;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;color:var(--muted)}

/* ── Nav ── */
nav{position:sticky;top:0;z-index:50;background:rgba(242,247,244,0.82);backdrop-filter:saturate(140%) blur(12px);border-bottom:1px solid transparent;transition:border-color .3s}
nav.scrolled{border-color:var(--line)}
.nav-inner{display:flex;align-items:center;justify-content:space-between;height:64px}
.brand{display:flex;align-items:center;gap:11px;font-weight:600;font-size:16px}
.brand-mark{width:30px;height:30px;display:flex;align-items:center;justify-content:center}
.brand-mark svg{width:30px;height:30px;display:block}
.nav-links{display:flex;align-items:center;gap:30px;font-size:14px;color:var(--ink-soft)}
.nav-links a:hover{color:var(--ink)}
.nav-cta{background:var(--teal);color:#fff;padding:9px 16px;border-radius:9px;font-size:13.5px;font-weight:500;transition:transform .12s,background .2s}
.nav-cta:hover{background:var(--teal-deep);transform:translateY(-1px)}
@media(max-width:720px){.nav-links a:not(.nav-cta){display:none}}

/* ── Hero ── */
.hero{padding:88px 0 36px;text-align:center}
.hero-tag{display:inline-flex;align-items:center;gap:8px;font-size:13px;color:var(--ink-soft);background:var(--cream);border:1px solid var(--line);padding:6px 14px;border-radius:30px;margin-bottom:28px}
.hero-tag .dot{width:6px;height:6px;border-radius:50%;background:var(--teal)}
.hero h1{font-size:clamp(40px,7vw,76px);margin-bottom:22px}
.hero h1 .accent{font-style:italic;color:var(--teal-deep)}
.hero p.lede{font-size:clamp(17px,2.2vw,20px);color:var(--ink-soft);max-width:600px;margin:0 auto 34px;line-height:1.55}
.hero-actions{display:flex;gap:14px;justify-content:center;align-items:center;flex-wrap:wrap}
.btn-primary{display:inline-flex;align-items:center;gap:10px;background:var(--teal);color:#fff;padding:14px 26px;border-radius:11px;font-weight:500;font-size:16px;transition:transform .12s,background .2s,box-shadow .2s;box-shadow:var(--shadow)}
.btn-primary:hover{background:var(--teal-deep);transform:translateY(-2px)}
.btn-ghost{display:inline-flex;align-items:center;gap:8px;color:var(--ink-soft);padding:14px 18px;font-weight:500;font-size:15px}
.btn-ghost:hover{color:var(--ink)}
.hero-note{margin-top:16px;font-size:13px;color:var(--muted)}

/* ── Signature demo ── */
.signature{padding:44px 0 24px}
.demo-frame{position:relative;border-radius:18px;overflow:hidden;border:1px solid var(--line);background:var(--cream);box-shadow:var(--shadow)}
.demo-head{display:flex;align-items:center;gap:8px;padding:13px 16px;border-bottom:1px solid var(--line);background:var(--paper)}
.tdot{width:11px;height:11px;border-radius:50%;background:#cdded6}
.demo-url{margin-left:12px;font-size:12.5px;color:var(--muted)}
.demo-replay{margin-left:auto;font:inherit;font-size:12.5px;font-weight:500;border:1px solid var(--line);background:var(--cream);color:var(--ink-soft);padding:5px 12px;border-radius:7px;cursor:pointer;transition:border-color .2s,color .2s}
.demo-replay:hover{border-color:var(--teal);color:var(--teal-deep)}
.demo-stage{position:relative;height:400px;background:#fff;overflow:hidden}
@media(max-width:640px){.demo-stage{height:360px}}

/* workspace mock: a toolbelt rail + a canvas that transforms */
.ws{position:absolute;inset:0;display:flex}
.ws-rail{width:150px;flex-shrink:0;border-right:1px solid var(--line);background:var(--paper);padding:14px 10px;display:flex;flex-direction:column;gap:5px}
@media(max-width:640px){.ws-rail{width:112px}}
.ws-tool{display:flex;align-items:center;gap:8px;font-size:12px;color:var(--ink-soft);padding:7px 9px;border-radius:8px;transition:background .25s,color .25s;position:relative}
.ws-tool .tdotmark{width:15px;height:15px;flex-shrink:0;color:var(--muted);transition:color .25s}
.ws-tool.active{background:var(--teal-soft);color:var(--teal-deep);font-weight:500}
.ws-tool.active .tdotmark{color:var(--teal-deep)}
.ws-tool .propill{position:absolute;right:7px;font-size:8px;font-weight:700;letter-spacing:.04em;color:var(--gold);background:var(--gold-soft);padding:1px 4px;border-radius:3px}
@media(max-width:640px){.ws-tool span.lbl{font-size:11px}.ws-tool .propill{display:none}}

.ws-canvas{flex:1;position:relative;background:linear-gradient(180deg,#fff,#fbfdfc);overflow:hidden}
.stage-cap{position:absolute;left:50%;bottom:16px;transform:translateX(-50%);font-size:12.5px;color:var(--muted);background:rgba(255,255,255,.9);padding:5px 14px;border-radius:20px;white-space:nowrap;z-index:20;box-shadow:0 2px 8px rgba(19,33,29,.06)}

/* generic page tiles used across scenes */
.pg{position:absolute;border-radius:8px;background:#fff;border:1px solid var(--line);box-shadow:0 6px 18px rgba(19,33,29,.10);overflow:hidden}
.pg .pg-lines{padding:12px}
.pg .l{height:6px;border-radius:3px;background:#eef1ef;margin-bottom:7px}
.pg .l.s{width:55%}.pg .l.m{width:80%}.pg .l.lg{width:95%}
.pg .pg-img{height:34px;margin:8px 12px;border-radius:6px;background:linear-gradient(120deg,#d7ece3,#bfe0d2)}

.scene{position:absolute;inset:0;opacity:0;transition:opacity .4s;pointer-events:none}
.scene.show{opacity:1}

/* merge scene: three pages slide into one stack */
#sc-merge .pg{width:88px;height:112px;top:70px}
#sc-merge .p1{left:40px}#sc-merge .p2{left:130px}#sc-merge .p3{left:220px}
#sc-merge .merged{left:150px;top:64px;width:96px;height:124px;box-shadow:0 12px 30px rgba(19,33,29,.18);opacity:0}
#sc-merge .badge{position:absolute;left:50%;top:210px;transform:translateX(-50%);background:var(--teal);color:#fff;font-size:11px;font-weight:600;padding:3px 10px;border-radius:20px;opacity:0}

/* convert scene: word doc -> pdf */
#sc-convert .docx{left:70px;top:74px;width:96px;height:120px}
#sc-convert .docx .tag{position:absolute;top:8px;left:8px;background:#2b579a;color:#fff;font-size:9px;font-weight:700;padding:1px 5px;border-radius:3px}
#sc-convert .arrow{position:absolute;left:180px;top:126px;color:var(--teal);opacity:0}
#sc-convert .pdf{left:230px;top:74px;width:96px;height:120px;opacity:0}
#sc-convert .pdf .tag{position:absolute;top:8px;left:8px;background:#c0392b;color:#fff;font-size:9px;font-weight:700;padding:1px 5px;border-radius:3px}

/* sign scene: a signature stroke appears on a page */
#sc-sign .pg{left:120px;top:60px;width:150px;height:140px}
#sc-sign svg.sig{position:absolute;left:150px;top:150px;overflow:visible}
#sc-sign svg.sig path{stroke:var(--teal-deep);stroke-width:2.4;fill:none;stroke-linecap:round;stroke-dasharray:220;stroke-dashoffset:220}

/* redact scene: black bars drop over lines */
#sc-redact .pg{left:110px;top:56px;width:170px;height:150px}
#sc-redact .bar{position:absolute;height:10px;border-radius:2px;background:#13211d;opacity:0;transform:scaleX(0);transform-origin:left}

/* translate scene: text lines flip language */
#sc-translate .pg{left:120px;top:60px;width:150px;height:140px}
#sc-translate .globe{position:absolute;right:40px;top:96px;color:var(--teal);opacity:.9}

/* ── Trust strip ── */
.strip{padding:34px 0;text-align:center;color:var(--muted);font-size:13.5px}
.strip b{color:var(--ink-soft);font-weight:600}

/* ── Sections ── */
section.block{padding:80px 0}
.section-head{max-width:620px;margin-bottom:52px}
.section-head.center{margin-left:auto;margin-right:auto;text-align:center}
.section-head h2{font-size:clamp(30px,4.4vw,44px);margin:14px 0 16px}
.section-head p{font-size:17px;color:var(--ink-soft)}

/* ── Features ── */
.features{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
@media(max-width:860px){.features{grid-template-columns:repeat(2,1fr)}}
@media(max-width:560px){.features{grid-template-columns:1fr}}
.feature{background:var(--cream);border:1px solid var(--line);border-radius:15px;padding:26px 24px;transition:transform .18s,box-shadow .18s}
.feature:hover{transform:translateY(-3px);box-shadow:var(--shadow)}
.feature .ic{width:42px;height:42px;border-radius:11px;background:var(--teal-soft);display:flex;align-items:center;justify-content:center;margin-bottom:16px;color:var(--teal-deep)}
.feature h3{font-size:17px;font-weight:600;margin-bottom:7px;display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.feature p{font-size:14.5px;color:var(--ink-soft);line-height:1.55}
.pro-pill{font-size:10px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;color:var(--gold);background:var(--gold-soft);padding:2px 7px;border-radius:5px}

/* ── Privacy callout (dark band) ── */
.rclick{background:var(--ink);color:#fff;border-radius:20px;padding:48px 44px;display:grid;grid-template-columns:1.1fr .9fr;gap:36px;align-items:center}
@media(max-width:760px){.rclick{grid-template-columns:1fr;padding:36px 28px}}
.rclick h2{font-size:clamp(26px,3.6vw,36px);margin-bottom:14px}
.rclick p{color:#c4d2cc;font-size:16px;max-width:44ch}
.rclick .mini-list{margin-top:18px;display:flex;flex-wrap:wrap;gap:8px}
.rclick .mini-list span{font-size:12px;color:#dfe9e5;background:#1c2d28;border:1px solid #2c413a;padding:4px 10px;border-radius:20px}
/* device-vs-cloud diagram */
.privacy-viz{background:#1c2d28;border:1px solid #2c413a;border-radius:14px;padding:22px;display:flex;flex-direction:column;gap:14px}
.pv-row{display:flex;align-items:center;gap:12px;font-size:13px}
.pv-row .pv-ic{width:34px;height:34px;border-radius:9px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.pv-yours .pv-ic{background:rgba(29,158,117,.18);color:var(--teal-soft)}
.pv-yours{color:#fff}
.pv-them .pv-ic{background:rgba(255,255,255,.06);color:#8ea098}
.pv-them{color:#8ea098}
.pv-them .x{margin-left:auto;color:#c0705f;font-size:16px}
.pv-yours .check{margin-left:auto;color:var(--teal-soft);font-size:16px}
.pv-divider{height:1px;background:#2c413a}

/* ── Pricing ── */
.pricing{display:grid;grid-template-columns:1fr 1fr;gap:22px;max-width:760px;margin:0 auto}
@media(max-width:680px){.pricing{grid-template-columns:1fr}}
.plan{background:var(--cream);border:1px solid var(--line);border-radius:18px;padding:32px}
.plan.pro{border-color:var(--gold);position:relative;box-shadow:0 8px 30px rgba(184,134,11,.10)}
.plan.pro::before{content:'Launch offer';position:absolute;top:-11px;left:32px;background:var(--gold);color:#fff;font-size:11px;font-weight:600;letter-spacing:.04em;padding:3px 11px;border-radius:20px}
.plan h3{font-family:'Fraunces',serif;font-weight:500;font-size:22px;margin-bottom:6px}
.plan .price{display:flex;align-items:baseline;gap:9px;margin:14px 0 4px}
.plan .price .now{font-size:40px;font-weight:600;font-family:'Fraunces',serif;letter-spacing:-.02em}
.plan .price .was{font-size:19px;color:var(--muted);text-decoration:line-through}
.plan .price-sub{font-size:13.5px;color:var(--muted);margin-bottom:22px}
.plan ul{list-style:none;display:flex;flex-direction:column;gap:11px;margin-bottom:26px}
.plan li{display:flex;gap:11px;font-size:14.5px;color:var(--ink-soft);align-items:flex-start}
.plan li .tick{flex-shrink:0;margin-top:3px}
.tick.free{color:var(--teal)}
.tick.pro{color:var(--gold)}
.plan .plan-cta{display:block;text-align:center;padding:13px;border-radius:11px;font-weight:500;font-size:15px;transition:transform .12s,background .2s}
.plan-cta.dark{background:var(--teal);color:#fff}
.plan-cta.dark:hover{background:var(--teal-deep);transform:translateY(-2px)}
.plan-cta.gold{background:var(--gold);color:#fff}
.plan-cta.gold:hover{background:#a3760a;transform:translateY(-2px)}
.plan .micro{text-align:center;font-size:12px;color:var(--muted);margin-top:11px}
/* competitor anchor */
.anchor{text-align:center;margin-top:30px;font-size:14px;color:var(--ink-soft)}
.anchor b{color:var(--ink);font-weight:600}
.anchor .vs{display:inline-flex;flex-wrap:wrap;gap:8px 18px;justify-content:center;margin-top:12px}
.anchor .vs span{color:var(--muted)}
.anchor .vs .dk{color:var(--teal-deep);font-weight:600}

/* ── FAQ ── */
.faq{max-width:720px;margin:0 auto}
.qa{border-bottom:1px solid var(--line)}
.qa summary{cursor:pointer;list-style:none;padding:22px 4px;font-weight:500;font-size:17px;display:flex;justify-content:space-between;align-items:center;gap:16px}
.qa summary::-webkit-details-marker{display:none}
.qa summary .plus{color:var(--muted);font-size:22px;transition:transform .2s;flex-shrink:0}
.qa[open] summary .plus{transform:rotate(45deg)}
.qa .a{padding:0 4px 22px;color:var(--ink-soft);font-size:15px;line-height:1.65;max-width:64ch}

/* ── Final CTA ── */
.final{background:var(--ink);color:#fff;border-radius:24px;padding:64px 40px;text-align:center;margin:40px 0}
.final h2{font-size:clamp(30px,4.5vw,46px);margin-bottom:18px}
.final p{color:#c4d2cc;font-size:17px;max-width:520px;margin:0 auto 30px}
.final .btn-primary{background:#fff;color:var(--ink)}
.final .btn-primary:hover{background:#f0f0f0}
.final .micro{margin-top:18px;font-size:13px;color:#8ea098}

/* ── Footer ── */
footer{padding:48px 0 60px;border-top:1px solid var(--line);color:var(--muted);font-size:13.5px}
.foot-inner{display:flex;justify-content:space-between;gap:24px;flex-wrap:wrap;align-items:center}
.foot-links{display:flex;gap:22px;flex-wrap:wrap}
.foot-links a:hover{color:var(--ink)}
.foot-legal{margin-top:18px;font-size:12.5px;color:var(--muted);line-height:1.6}

@media(prefers-reduced-motion:reduce){*{transition:none!important;scroll-behavior:auto!important;animation:none!important}}
</style>
</head>
<body>

<!-- NAV -->
<nav id="nav">
  <div class="wrap nav-inner">
    <a class="brand" href="/dockit">
      <span class="brand-mark">
        <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect x="18" y="12" width="52" height="68" rx="8" fill="#1D9E75"/>
          <rect x="30" y="20" width="52" height="68" rx="8" fill="#0f6e56"/>
          <path d="M46 54l7 7 14-14" stroke="#fff" stroke-width="6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span> DocKit
    </a>
    <div class="nav-links">
      <a href="#features">Features</a>
      <a href="#pricing">Pricing</a>
      <a href="#faq">FAQ</a>
      <a class="nav-cta" id="nav-install" href="#install">Add to Chrome</a>
    </div>
  </div>
</nav>

<!-- HERO -->
<header class="hero">
  <div class="wrap">
    <span class="hero-tag"><span class="dot"></span> Free to install · Pro unlocks more</span>
    <h1 class="display">Every document tool. <span class="accent">One</span> place.</h1>
    <p class="lede">DocKit is your complete PDF, Word &amp; Excel toolkit — merge, split, compress and convert, eSign, OCR, redact and translate whole documents. All 100% on your device. No account, nothing uploaded.</p>
    <div class="hero-actions">
      <a class="btn-primary" id="hero-install" href="#install">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.5"/><path d="M10 6v8M6 10h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        Add to Chrome — it's free
      </a>
      <a class="btn-ghost" href="#demo">See it in action ↓</a>
    </div>
    <p class="hero-note">Works on Chrome, Edge, Brave &amp; other Chromium browsers</p>
  </div>
</header>

<!-- SIGNATURE DEMO -->
<section class="signature" id="demo">
  <div class="wrap">
    <div class="demo-frame">
      <div class="demo-head">
        <span class="tdot"></span><span class="tdot"></span><span class="tdot"></span>
        <span class="demo-url">DocKit · one workspace, every document tool</span>
        <button class="demo-replay" id="replay">↻ Replay</button>
      </div>
      <div class="demo-stage">
        <div class="ws">
          <div class="ws-rail" id="rail">
            <div class="ws-tool" data-tool="merge"><span class="tdotmark"><svg viewBox="0 0 20 20" fill="none"><path d="M4 6h6v8H4zM12 4h4v12h-4z" stroke="currentColor" stroke-width="1.4"/></svg></span><span class="lbl">Merge</span></div>
            <div class="ws-tool" data-tool="convert"><span class="tdotmark"><svg viewBox="0 0 20 20" fill="none"><path d="M4 7h8m0 0l-3-3m3 3l-3 3M16 13H8m0 0l3-3m-3 3l3 3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg></span><span class="lbl">Convert</span></div>
            <div class="ws-tool" data-tool="sign"><span class="tdotmark"><svg viewBox="0 0 20 20" fill="none"><path d="M3 16h14M5 13l8-8 2 2-8 8H5v-2z" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg></span><span class="lbl">eSign</span></div>
            <div class="ws-tool" data-tool="redact"><span class="tdotmark"><svg viewBox="0 0 20 20" fill="none"><rect x="3" y="5" width="14" height="10" rx="1.5" stroke="currentColor" stroke-width="1.4"/><path d="M6 9h5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg></span><span class="lbl">Redact</span><span class="propill">Pro</span></div>
            <div class="ws-tool" data-tool="translate"><span class="tdotmark"><svg viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="7" stroke="currentColor" stroke-width="1.4"/><path d="M3 10h14M10 3c2.5 2 2.5 12 0 14M10 3c-2.5 2-2.5 12 0 14" stroke="currentColor" stroke-width="1.4"/></svg></span><span class="lbl">Translate</span><span class="propill">Pro</span></div>
          </div>

          <div class="ws-canvas" id="canvas">
            <!-- MERGE -->
            <div class="scene" id="sc-merge">
              <div class="pg p1"><div class="pg-lines"><div class="l lg"></div><div class="l m"></div><div class="l s"></div></div></div>
              <div class="pg p2"><div class="pg-lines"><div class="l m"></div><div class="l lg"></div><div class="l s"></div></div></div>
              <div class="pg p3"><div class="pg-lines"><div class="l lg"></div><div class="l s"></div><div class="l m"></div></div></div>
              <div class="pg merged" id="mergedPg"><div class="pg-lines"><div class="l lg"></div><div class="l m"></div><div class="l lg"></div><div class="l s"></div><div class="l m"></div></div></div>
              <div class="badge" id="mergeBadge">1 PDF ✓</div>
            </div>
            <!-- CONVERT -->
            <div class="scene" id="sc-convert">
